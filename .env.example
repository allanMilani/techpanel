# --- App ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# --- PostgreSQL (par com docker-compose) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=techpanel

# --- JWT (login) — gere um segredo forte em produção ---
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Criptografia Fernet (chaves SSH em repouso) ---
# Gerar: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# --- GitHub OAuth (preencher quando for integrar) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_URL=http://localhost:8000/auth/github/callback
GITHUB_OAUTH_SCOPE=repo,read:org